generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

// ─────────────────────────────────────────────
// Models
// ─────────────────────────────────────────────

model Appointment {
  id          String            @id @default(cuid())
  patientName String
  email       String
  phone       String
  specialtyId String
  doctorId    String?
  locationId  String
  date        DateTime
  timeSlot    String
  status      AppointmentStatus @default(PENDING)
  notes       String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  specialty Specialty @relation(fields: [specialtyId], references: [id])
  doctor    Doctor?   @relation(fields: [doctorId], references: [id])
  location  Location  @relation(fields: [locationId], references: [id])

  @@index([email])
  @@index([specialtyId])
  @@index([doctorId])
  @@index([locationId])
  @@index([date])
  @@index([status])
}

model Doctor {
  id         String   @id @default(cuid())
  name       String
  specialty  String
  crm        String   @unique
  bio        String?
  photoUrl   String?
  available  Boolean  @default(true)
  locationId String
  createdAt  DateTime @default(now())

  location     Location      @relation(fields: [locationId], references: [id])
  appointments Appointment[]
  specialties  Specialty[]   @relation("DoctorSpecialties")

  @@index([locationId])
  @@index([available])
}

model Specialty {
  id          String @id @default(cuid())
  name        String
  slug        String @unique
  description String
  icon        String

  appointments Appointment[]
  doctors      Doctor[]      @relation("DoctorSpecialties")
}

model Location {
  id       String  @id @default(cuid())
  name     String
  address  String
  phone    String
  email    String?
  whatsapp String?
  mapUrl   String?
  hours    String

  doctors      Doctor[]
  appointments Appointment[]
}

model Testimonial {
  id          String   @id @default(cuid())
  patientName String
  text        String
  rating      Int
  specialty   String?
  approved    Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([approved])
  @@index([rating])
}

model BlogPost {
  id            String    @id @default(cuid())
  title         String
  slug          String    @unique
  excerpt       String
  content       String    @db.Text
  coverImageUrl String?
  category      String
  authorName    String
  published     Boolean   @default(false)
  publishedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([published])
  @@index([category])
  @@index([publishedAt])
}

model InsurancePlan {
  id           String  @id @default(cuid())
  name         String
  logoUrl      String?
  category     String
  active       Boolean @default(true)
  displayOrder Int     @default(0)

  @@index([active])
  @@index([displayOrder])
}
